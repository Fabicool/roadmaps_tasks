<?xml version="1.0" ?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Webapi:etc/webapi.xsd">
	<route url="/V1/fabicool-apiroadmap/bestsellers" method="GET">
		<service class="Fabicool\ApiRoadmap\Api\BestsellersManagementInterface" method="getBestsellers"/>
		<resources>
			<resource ref="anonymous"/>
		</resources>
	</route>
	<route url="/V1/fabicool-apiroadmap/new" method="GET">
		<service class="Fabicool\ApiRoadmap\Api\NewManagementInterface" method="getNew"/>
		<resources>
			<resource ref="anonymous"/>
		</resources>
	</route>
	<route url="/V1/fabicool-apiroadmap/tree" method="GET">
		<service class="Fabicool\ApiRoadmap\Api\TreeManagementInterface" method="getTree"/>
		<resources>
			<resource ref="anonymous"/>
		</resources>
	</route>
	<route url="/V1/fabicool-apiroadmap/subscribe" method="POST">
		<service class="Fabicool\ApiRoadmap\Api\SubscribeManagementInterface" method="postSubscribe"/>
		<resources>
			<resource ref="anonymous"/>
		</resources>
	</route>
</routes>
